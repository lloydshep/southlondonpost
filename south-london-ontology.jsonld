  "@graph": [
    {
      "@id": "https://southlondon.place/ontology",
      "@type": "skos:ConceptScheme",
      "dcterms:title": "South London Place Ontology",
      "dcterms:description": "A four-level hierarchical ontology of places in South London, for use in local content aggregation. Each node is cross-referenced to authoritative public sources.",
      "dcterms:creator": "South London Place Project",
      "dcterms:license": "https://creativecommons.org/licenses/by/4.0/",
      "dcterms:created": "2025-01-01",
      "dcterms:source": [
        "https://statistics.data.gov.uk/",
        "https://www.openstreetmap.org/",
        "https://www.wikidata.org/",
        "https://api.tfl.gov.uk/"
      ],
      "boroughInclusionRule": {
        "rule": "A London borough is included in this ontology if and only if it satisfies both of the following criteria: (1) it is one of the twelve statutory Inner London boroughs as defined by Schedule 1 of the London Government Act 1963 (c.33); and (2) it lies south of the River Thames.",
        "resultingBoroughs": [
          "London Borough of Lambeth",
          "London Borough of Southwark",
          "London Borough of Wandsworth",
          "London Borough of Lewisham",
          "Royal Borough of Greenwich"
        ],
        "explicitExclusions": {
          "outerLondonBoroughs": "Croydon, Bromley, Merton, Sutton, Bexley, Kingston upon Thames and Richmond upon Thames are all south of the Thames but are Outer London boroughs under the 1963 Act and therefore outside scope.",
          "innerLondonNorthOfThames": "Camden, Hackney, Hammersmith and Fulham, Islington, Kensington and Chelsea, Tower Hamlets, and Westminster are statutory Inner London boroughs but lie north of the Thames and are therefore outside scope.",
          "richmond": "Richmond upon Thames straddles both banks of the Thames but is classified as an Outer London borough under the 1963 Act and is therefore outside scope regardless of its partial southern extent."
        },
        "greenwichNote": "The Royal Borough of Greenwich has a small northern section that touches the Thames at East Greenwich, but the borough is unambiguously classified as a south-of-Thames Inner London borough in all authoritative sources.",
        "legislativeCitation": {
          "title": "London Government Act 1963",
          "schedule": "Schedule 1 — The London Boroughs",
          "chapter": "c.33",
          "url": "https://www.legislation.gov.uk/ukpga/1963/33/schedule/1",
          "publisher": "Her Majesty's Stationery Office",
          "accessedVia": "https://www.legislation.gov.uk/"
        },
        "alternativeDefinitionsConsidered": [
          {
            "name": "Boundary Commission for England 2011 grouping",
            "boroughCount": 12,
            "reasonRejected": "Includes Outer London boroughs (Croydon, Bromley, Merton, Sutton, Bexley, Kingston, Richmond) which significantly extends the geographic scope beyond the inner-city focus of this service."
          },
          {
            "name": "GLA South West sub-region (London Plan 2008)",
            "boroughCount": 7,
            "reasonRejected": "Excludes Southwark, Lewisham, and Greenwich — placing Peckham and Greenwich outside South London, which contradicts common usage and editorial intent."
          },
          {
            "name": "GLA South East sub-region (London Plan 2008)",
            "boroughCount": 5,
            "reasonRejected": "Excludes Lambeth and Wandsworth, omitting Brixton, Clapham, Tooting and Battersea — again contradicting common usage."
          },
          {
            "name": "River Thames boundary (popular convention)",
            "boroughCount": 12,
            "reasonRejected": "No statutory basis; boundary is informal and not citable to a single authoritative source."
          }
        ]
      },
      "skos:hasTopConcept": {
        "@id": "place:south-london"
      }
    },
    {
      "@id": "https://southlondon.place/ontology/levels",
      "@type": "skos:Collection",
      "skos:prefLabel": "Place level definitions",
      "skos:member": [
        {
          "@id": "level:region",
          "skos:prefLabel": "Region",
          "skos:definition": "Top-level geographic region. In this ontology: South London as a whole.",
          "skos:example": "South London",
          "dcterms:source": "https://statistics.data.gov.uk/id/statistical-geography/E13000002"
        },
        {
          "@id": "level:borough",
          "skos:prefLabel": "Borough",
          "skos:definition": "London Borough — a statutory local government area defined by the London Government Act 1963.",
          "skos:example": "London Borough of Lambeth",
          "dcterms:source": "https://statistics.data.gov.uk/id/statistical-geography/E09000022"
        },
        {
          "@id": "level:neighbourhood",
          "skos:prefLabel": "Neighbourhood",
          "skos:definition": "A commonly recognised sub-area within a borough. May align with an electoral ward but is primarily defined by popular usage and OSM data.",
          "skos:example": "Brixton",
          "dcterms:source": "https://www.openstreetmap.org/"
        },
        {
          "@id": "level:landmark",
          "skos:prefLabel": "Landmark / Street / Site",
          "skos:definition": "A specific named place, street, market, park, or institution within a neighbourhood.",
          "skos:example": "Brixton Market",
          "dcterms:source": "https://www.openstreetmap.org/"
        }
      ]
    },
