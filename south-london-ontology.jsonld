  "_meta": {
    "schemaVersion": "0.2.0",
    "ontologyStatus": "prototype",
    "coverage": "Five statutory Inner London boroughs south of the Thames (London Government Act 1963, Schedule 1): Lambeth, Southwark, Lewisham, Wandsworth, Greenwich. Selected neighbourhoods and landmarks within each. Borough inclusion rule now formally documented.",
    "primarySources": {
      "ONS": {
        "description": "Office for National Statistics statistical geographies",
        "baseUrl": "https://statistics.data.gov.uk/",
        "licence": "Open Government Licence v3.0",
        "licenceUrl": "https://www.nationalarchives.gov.uk/doc/open-government-licence/",
        "used_for": [
          "onsCode",
          "borough boundaries",
          "ward boundaries"
        ]
      },
      "OrdnanceSurvey": {
        "description": "OS Boundary-Line and AddressBase products",
        "baseUrl": "https://osdatahub.os.uk/",
        "licence": "OS Open Data Licence",
        "licenceUrl": "https://www.ordnancesurvey.co.uk/documents/licensing/data-licence.pdf",
        "used_for": [
          "official boundary geometries",
          "UPRN references"
        ]
      },
      "OpenStreetMap": {
        "description": "OpenStreetMap collaborative geographic database",
        "baseUrl": "https://www.openstreetmap.org/",
        "licence": "Open Database Licence (ODbL) 1.0",
        "licenceUrl": "https://opendatacommons.org/licenses/odbl/",
        "used_for": [
          "osmId",
          "neighbourhood boundaries",
          "landmark geometries",
          "aliases"
        ]
      },
